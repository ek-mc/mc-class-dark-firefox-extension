{
  "manifest_version": 3,
  "name": "MC-Class Dark Theme (Gecko)",
  "version": "0.1.5",
  "description": "Applies a dark theme to mc-class.gr",
  "browser_specific_settings": {
    "gecko": {
      "id": "mc-class-dark-theme@ek-mc",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://mc-class.gr/*",
        "*://*.mc-class.gr/*"
      ],
      "css": ["dark.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
