{
  "manifest_version": 3,
  "name": "MC-Class Dark Theme (Gecko)",
  "version": "0.1.14",
  "description": "Applies a dark theme to mc-class.gr",
  "browser_specific_settings": {
    "gecko": {
      "id": "mc-class-dark-theme@ek-mc",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://mc-class.gr/*",
        "*://*.mc-class.gr/*"
      ],
      "css": [
        "dark.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
